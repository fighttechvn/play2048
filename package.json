{
  "name": "go2048",
  "version": "1.1.1",
  "private": true,
  "description": "go2048 — an H5 2048 game built with PixiJS v7, packaged for iOS 13+ & Android with Capacitor 6 (Ionic).",
  "type": "module",
  "scripts": {
    "games": "bash games/build.sh",
    "dev": "vite",
    "prebuild": "bash games/build.sh",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "sync": "npm run build && cap sync",
    "open:ios": "cap open ios",
    "open:android": "cap open android",
    "postinstall": "patch-package && bash games/build.sh"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/app": "^6.0.2",
    "@capacitor/core": "^6.2.1",
    "@capacitor/haptics": "^6.0.2",
    "@capacitor/ios": "^6.2.1",
    "@capacitor/preferences": "^6.0.3",
    "@capacitor/splash-screen": "^6.0.3",
    "@capacitor/status-bar": "^6.0.2",
    "pixi.js": "^7.4.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.1",
    "patch-package": "^8.0.1",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
