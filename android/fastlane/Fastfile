# Fastlane — Android / Google Play (go2048, Capacitor)
# Adapted from the shipflutter `store-release` skill: builds the AAB with Gradle
# (not Flutter) since this is a Capacitor app.
#
#   cd android
#   bundle exec fastlane validate     # check service-account access (no upload)
#   bundle exec fastlane internal     # build AAB + upload to internal track (draft)
#   bundle exec fastlane promote_to_production
#
# Env (load .env.prod first): PLAYSTORE_SERVICE_ACCOUNT_JSON, PLAYSTORE_PACKAGE_NAME.
# Requires JDK 21 + ANDROID_HOME (see ../scripts/env.sh).

default_platform(:android)

ANDROID_DIR = File.expand_path("..", __dir__)
AAB = File.join(ANDROID_DIR, "app/build/outputs/bundle/release/app-release.aab")
TRACK = ENV.fetch("PLAYSTORE_TRACK", "internal")

platform :android do
  desc "Build a signed release AAB with Gradle"
  lane :build_aab do
    gradle(project_dir: ANDROID_DIR, task: "bundle", build_type: "Release")
    UI.user_error!("AAB not found at #{AAB}") unless File.exist?(AAB)
    UI.success("Built #{AAB}")
  end

  desc "Validate Play service-account access (no upload, no metadata)"
  lane :validate do
    upload_to_play_store(
      track: TRACK,
      validate_only: true,
      skip_upload_aab: true,
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
  end

  desc "Build + upload AAB to the internal testing track (draft)"
  lane :internal do
    build_aab
    upload_to_play_store(
      track: "internal",
      aab: AAB,
      release_status: "draft",
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
  end

  desc "Promote the latest internal build to production (use with care)"
  lane :promote_to_production do
    upload_to_play_store(
      track: "internal",
      track_promote_to: "production",
      skip_upload_aab: true,
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
  end
end
